[user]
    name = Novbi
    email = para.12.dev@gmail.com
    useConfigOnly = true

[core]
    editor = nvim
    autocrlf = input
    pager = delta

[init]
    defaultBranch = main

[pull]
    rebase = true

[fetch]
    prune = true
    pruneTags = true
    all = true

[push]
    autoSetupRemote = true
    useForceIfIncludes = true

[commit]
    verbose = true

[rebase]
    autoStash = true
    autoSquash = true
    updateRefs = true

[rerere]
    enabled = true
    autoupdate = true

[diff]
    algorithm = histogram
    mnemonicPrefix = true
    colorMoved = plain
    renames = true
    tool = delta

[interactive]
    mnemonicPrefix = true
    wordRegex = "[^[:space:]]|([[:alnum:]]|UTF_8_GUARD)+"
    diffFilter = delta --color-only

[merge]
    conflictstyle = zdiff3
    defaultToUpstream = true
    tool = delta

[mergetool]
    keepBackup = false

[pretty]
    line = "%C(auto)%h %<|(60,trunc)%s %C(green)%ad%C(auto)%d"
    detail = "%C(auto)%h %s%n  %C(yellow)by %C(blue)%an %C(magenta)<%ae> [%G?] %C(green)%ad%n %C(auto)%d%n"

[color]
    ui = auto

[color "grep"]
    match = cyan bold
    selected = blue
    context = normal
    filename = magenta
    linenumber = green
    separator = yellow
    function = blue

[delta]
    navigate = true
    line-numbers = true
    side-by-side = true
    syntax-theme = Dracula

[column]
    ui = auto

[branch]
    sort = -committerdate

[tag]
    sort = version:refname

[help]
    autocorrect = prompt

[alias]
    p = push
    a = add
    aa = add .
    c = commit
    ca = commit --amend --no-edit
    cma = commit --amend
    pf = push --force-with-lease
    pl = pull
    b = branch
    bd = branch -d
    bD = branch -D
    sw = switch
    swc = switch -c
    ss = stash save
    sp = stash pop
    sl = stash list
    clean-dry = clean -nfd
    clean-go = clean -fd
    s = status -sb
    d = diff
    dlast = show HEAD
    ds = diff --staged
    lg = log --oneline --graph --decorate --all
    last = log -1 HEAD
    undo = reset --soft HEAD~1
    unstage = restore --staged
    nuke = reset --hard HEAD
    aliases = config --get-regexp alias
